RewriteEngine On

# API routing
RewriteRule ^api/auth/signup$ api/signup.php [L,QSA]
RewriteRule ^api/auth/login$ api/login.php [L,QSA]
RewriteRule ^api/auth/me$ api/me.php [L,QSA]
RewriteRule ^api/units$ api/units.php [L,QSA]
RewriteRule ^api/units/([0-9]+)$ api/unit_detail.php?id=$1 [L,QSA]
RewriteRule ^api/dashboard$ api/dashboard.php [L,QSA]
RewriteRule ^api/analytics$ api/analytics.php [L,QSA]
RewriteRule ^api/study-sessions$ api/study_sessions.php [L,QSA]
RewriteRule ^api/test/list$ api/test-list.php [L,QSA]
RewriteRule ^api/test/start$ api/test-start.php [L,QSA]
RewriteRule ^api/test/([0-9]+)/questions$ api/test-questions.php?test_id=$1 [L,QSA]
RewriteRule ^api/test/save-answer$ api/test-save-answer.php [L,QSA]
RewriteRule ^api/test/submit$ api/test-submit.php [L,QSA]
RewriteRule ^api/test/result/([0-9]+)$ api/test-result.php?attempt_id=$1 [L,QSA]
RewriteRule ^api/test/resume/([0-9]+)$ api/test-resume.php?attempt_id=$1 [L,QSA]
RewriteRule ^healthz$ api/healthz.php [L,QSA]
